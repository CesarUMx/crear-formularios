---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  showUserMenu?: boolean;
  brand?: 'default' | 'umx';
}

const { title, description = 'Plataforma de formularios', showUserMenu = false, brand = 'default' } = Astro.props;
const isUmx = brand === 'umx';

// Obtener configuración de la plataforma
const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000/api';
let platformLogo = '/images/logo.svg'; // Logo por defecto
let primaryColor = '#2563eb'; // blue-600
let secondaryColor = '#1e40af'; // blue-800

try {
  const response = await fetch(`${API_URL}/settings`);
  if (response.ok) {
    const settings = await response.json();
    platformLogo = settings.logo || platformLogo;
    primaryColor = settings.primaryColor || primaryColor;
    secondaryColor = settings.secondaryColor || secondaryColor;
  }
} catch (error) {
  console.log('Usando configuración por defecto');
}
---

<!doctype html>
<html lang="es" translate="no">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="google" content="notranslate" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.ico" />
    {isUmx && (
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" />
    )}
    <title>{title}</title>
  </head>
  <body class={`min-h-screen flex flex-col ${isUmx ? 'bg-gray-50' : 'bg-gradient-to-br from-gray-50 via-blue-50 to-gray-50'}`} style={isUmx ? "font-family: 'Poppins', sans-serif;" : undefined}>
    {isUmx ? (
      <header class="w-full shadow-md" style="background-color: #FF4D00;">
        <div class="max-w-5xl mx-auto px-6 py-3 flex items-center">
          <img
            src="/images/Logo Uni_Blanco.png"
            alt="Universidad Mondragón México"
            class="h-16 w-auto object-contain"
          />
        </div>
      </header>
    ) : (
      <nav class="shadow-lg sticky top-0 z-50 backdrop-blur-sm" style={`background: linear-gradient(to right, ${primaryColor}, ${secondaryColor});`}>
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex justify-between h-16 items-center">
            <a href="/" class="flex items-center gap-3 group">
              <div class="p-2 rounded-xl transition-all duration-300 group-hover:scale-110">
                <img 
                  src={platformLogo} 
                  alt="Logo" 
                  class="w-10 h-10 object-contain drop-shadow-lg"
                  onerror="this.style.display='none'; this.nextElementSibling.style.display='block';"
                />
                <svg class="w-8 h-8 text-white hidden drop-shadow-lg" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                </svg>
              </div>
              <span class="text-xl font-bold text-white tracking-tight drop-shadow-md">Forms Platform</span>
            </a>
            <div class="flex items-center gap-4">
              {showUserMenu && (
                <span class="px-4 py-2 bg-white bg-opacity-20 rounded-full text-sm text-white font-medium backdrop-blur-sm">
                  Admin
                </span>
              )}
            </div>
          </div>
        </div>
      </nav>
    )}
    
    <!-- Main content -->
    <main class="flex-1">
      <slot />
    </main>
    
    {isUmx ? (
      <footer class="mt-auto py-6 px-6 text-center text-sm text-white/80" style="background-color: #0E5088;">
        <p class="font-medium text-white">Universidad Mondragón México</p>
        <p class="mt-1">Anillo Vial III Poniente no. 172 &nbsp;·&nbsp; (442) 40 210 00</p>
        <p class="mt-1">
          <a href="mailto:comunicacion@mondragonmexico.edu.mx" class="hover:text-white underline underline-offset-2">
            comunicacion@mondragonmexico.edu.mx
          </a>
        </p>
      </footer>
    ) : (
      <footer class="bg-gradient-to-r from-gray-900 via-gray-800 to-gray-900 text-white mt-auto">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
          <div class="flex flex-col md:flex-row justify-between items-center gap-4">
            <div class="flex items-center gap-3">
              <div class="p-2">
                <img 
                  src={platformLogo} 
                  alt="Logo" 
                  class="w-10 h-10 object-contain drop-shadow-lg"
                  onerror="this.style.display='none'; this.nextElementSibling.style.display='block';"
                />
                <svg class="w-8 h-8 text-white hidden drop-shadow-lg" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                </svg>
              </div>
              <div>
                <p class="font-semibold">Plataforma de Formularios</p>
                <p class="text-sm text-gray-400">Sistema de gestión de exámenes</p>
              </div>
            </div>
            <div class="flex flex-col items-center md:items-end gap-2">
              <p class="text-sm text-gray-400">&copy; 2025 Todos los derechos reservados</p>
              <div class="flex gap-4 text-xs text-gray-500">
                <a href="#" class="hover:text-blue-400 transition-colors">Términos</a>
                <span>•</span>
                <a href="#" class="hover:text-blue-400 transition-colors">Privacidad</a>
                <span>•</span>
                <a href="#" class="hover:text-blue-400 transition-colors">Soporte</a>
              </div>
            </div>
          </div>
        </div>
      </footer>
    )}
  </body>
</html>
