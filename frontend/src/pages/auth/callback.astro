---
// Página de callback para Google OAuth
// Recibe el token JWT como query param y lo guarda en localStorage
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <title>Iniciando sesión...</title>
    <style>
      body {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        margin: 0;
        font-family: system-ui, sans-serif;
        background-color: #f9fafb;
      }
      .spinner {
        width: 48px;
        height: 48px;
        border: 4px solid #e5e7eb;
        border-top-color: #2563eb;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
      }
      @keyframes spin {
        to { transform: rotate(360deg); }
      }
      p {
        margin-top: 16px;
        color: #6b7280;
        font-size: 14px;
      }
      .container {
        text-align: center;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="spinner"></div>
      <p>Iniciando sesión...</p>
    </div>

    <script>
      (function () {
        const params = new URLSearchParams(window.location.search);
        const token = params.get('token');
        const error = params.get('error');

        if (token) {
          try {
            // Decodificar payload del JWT (sin verificar firma — solo para extraer datos)
            const base64Payload = token.split('.')[1];
            const payload = JSON.parse(atob(base64Payload.replace(/-/g, '+').replace(/_/g, '/')));

            const user = {
              id: payload.id,
              email: payload.email,
              name: payload.name,
              role: payload.role,
            };

            localStorage.setItem('token', token);
            localStorage.setItem('user', JSON.stringify(user));
            window.location.replace('/admin');
          } catch {
            window.location.replace('/?error=invalid_token');
          }
        } else {
          window.location.replace('/?error=' + (error || 'auth_failed'));
        }
      })();
    </script>
  </body>
</html>
