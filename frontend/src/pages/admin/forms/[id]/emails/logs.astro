---
import AdminLayout from '../../../../../layouts/AdminLayout.astro';
import ProtectedRoute from '../../../../../components/auth/ProtectedRoute';
import EmailLogsViewer from '../../../../../components/forms/EmailLogsViewer';

export const prerender = false;

const { id } = Astro.params;

if (!id) {
  return Astro.redirect('/admin');
}
---

<AdminLayout title="Logs de email" currentPath="/admin">
  <ProtectedRoute client:load>
    <div>
      <!-- Header -->
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 mb-6">
        <nav class="flex items-center gap-1 text-sm text-gray-500 mb-4">
          <a href="/admin" class="hover:text-gray-700 transition">Admin</a>
          <span class="mx-1">›</span>
          <a href={`/admin/forms/${id}`} class="hover:text-gray-700 transition">Formulario</a>
          <span class="mx-1">›</span>
          <a href={`/admin/forms/${id}/emails`} class="hover:text-gray-700 transition">Correos</a>
          <span class="mx-1">›</span>
          <span class="text-gray-800 font-medium">Logs de envío</span>
        </nav>
        <div class="flex items-start justify-between gap-4">
          <div class="flex items-start gap-4">
            <div class="p-3 rounded-lg bg-gray-100">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
              </svg>
            </div>
            <div>
              <h1 class="text-2xl font-bold text-gray-900">Logs de envío</h1>
              <p class="text-gray-600 mt-1">Historial de todos los emails enviados y recordatorios programados</p>
            </div>
          </div>
          <div class="flex items-center gap-2 flex-shrink-0">
            <a
              href={`/admin/forms/${id}/emails`}
              class="px-4 py-2 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition text-sm font-medium"
            >
              ← Volver a Correos
            </a>
          </div>
        </div>

        <div class="mt-5 pt-4 border-t border-gray-100">
          <div class="flex flex-wrap gap-2">
            <a href={`/admin/forms/${id}/questions`} class="px-3 py-1.5 rounded-md text-sm font-medium transition bg-gray-100 text-gray-700 hover:bg-gray-200">Preguntas</a>
            <a href={`/admin/forms/${id}/exam`} class="px-3 py-1.5 rounded-md text-sm font-medium transition bg-gray-100 text-gray-700 hover:bg-gray-200">Examen</a>
            <a href={`/admin/forms/${id}/emails`} class="px-3 py-1.5 rounded-md text-sm font-medium transition bg-blue-600 text-white">Correos</a>
            <a href={`/admin/forms/${id}/responses`} class="px-3 py-1.5 rounded-md text-sm font-medium transition bg-gray-100 text-gray-700 hover:bg-gray-200">Respuestas</a>
            <a href={`/admin/forms/${id}/statistics`} class="px-3 py-1.5 rounded-md text-sm font-medium transition bg-gray-100 text-gray-700 hover:bg-gray-200">Estadísticas</a>
            <a href={`/admin/forms/${id}/hubspot`} class="px-3 py-1.5 rounded-md text-sm font-medium transition bg-gray-100 text-gray-700 hover:bg-gray-200">HubSpot</a>
          </div>
        </div>
      </div>

      <!-- Contenido -->
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <EmailLogsViewer formId={id} client:load />
      </div>
    </div>
  </ProtectedRoute>
</AdminLayout>
