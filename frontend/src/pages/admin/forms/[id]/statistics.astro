---
import AdminLayout from '../../../../layouts/AdminLayout.astro';
import ProtectedRoute from '../../../../components/auth/ProtectedRoute';
import StatisticsView from '../../../../components/forms/StatisticsView';
import FormNavTabs from '../../../../components/forms/FormNavTabs';

export const prerender = false;

const { id } = Astro.params;

if (!id) {
  return Astro.redirect('/admin');
}
---

<AdminLayout title="Estadísticas del Formulario" currentPath="/admin">
  <ProtectedRoute client:load>
    <div>
      <!-- Header -->
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 mb-6">
        <nav class="flex items-center gap-1 text-sm text-gray-500 mb-4">
          <a href="/admin" class="hover:text-gray-700 transition">Admin</a>
          <span class="mx-1">›</span>
          <a href={`/admin/forms/${id}`} class="hover:text-gray-700 transition">Formulario</a>
          <span class="mx-1">›</span>
          <span class="text-gray-800 font-medium">Estadísticas</span>
        </nav>
        <div class="flex items-start justify-between gap-4">
          <div class="flex items-start gap-4">
            <div class="p-3 rounded-lg bg-gray-100">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
              </svg>
            </div>
            <div>
              <h1 class="text-2xl font-bold text-gray-900">Estadísticas</h1>
              <p class="text-gray-600 mt-1">Análisis de las respuestas recibidas</p>
            </div>
          </div>
          <div class="flex items-center gap-2 flex-shrink-0">
            <a
              href={`/admin/forms/${id}/responses`}
              class="px-4 py-2 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition text-sm font-medium"
            >
              Ver Respuestas
            </a>
            <a
              href={`/admin/forms/${id}`}
              class="px-4 py-2 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition text-sm font-medium"
            >
              ← Volver al formulario
            </a>
          </div>
        </div>

        <FormNavTabs formId={id} currentSection="statistics" client:load />
        </div>
        </div>
      </div>

      <!-- Contenido -->
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <StatisticsView formId={id} client:load />
      </div>
      
      <script>
        // Script para exportar a CSV
        document.getElementById('exportCsvBtn')?.addEventListener('click', async () => {
          const formId = window.location.pathname.split('/').filter(Boolean)[2];
          if (!formId) return;
          
          try {
            const token = localStorage.getItem('token');
            if (!token) {
              alert('Necesitas iniciar sesión para exportar respuestas');
              return;
            }
            
            const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000/api';
            const exportUrl = `${API_URL}/analytics/forms/${formId}/export?format=csv&token=${token}`;
            window.open(exportUrl, '_blank');
          } catch (error) {
            console.error('Error al exportar respuestas:', error);
            alert('Error al exportar respuestas');
          }
        });
      </script>
    </div>
  </ProtectedRoute>
</AdminLayout>
